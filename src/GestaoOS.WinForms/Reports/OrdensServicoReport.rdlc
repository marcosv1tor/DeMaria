<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Body>
    <ReportItems>
      <Tablix Name="OrdensServicoTable">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>2.4cm</Width></TablixColumn>
            <TablixColumn><Width>4.6cm</Width></TablixColumn>
            <TablixColumn><Width>3cm</Width></TablixColumn>
            <TablixColumn><Width>3cm</Width></TablixColumn>
            <TablixColumn><Width>3cm</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>
            <TablixRow>
              <Height>0.7cm</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="HeaderId"><Value>OS</Value><Style><FontWeight>Bold</FontWeight></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="HeaderCliente"><Value>Cliente</Value><Style><FontWeight>Bold</FontWeight></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="HeaderData"><Value>Abertura</Value><Style><FontWeight>Bold</FontWeight></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="HeaderStatus"><Value>Status</Value><Style><FontWeight>Bold</FontWeight></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="HeaderTotal"><Value>Total</Value><Style><FontWeight>Bold</FontWeight></Style></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
            <TablixRow>
              <Height>0.6cm</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="OrdemServicoId"><Value>=Fields!OrdemServicoId.Value</Value></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="ClienteNome"><Value>=Fields!ClienteNome.Value</Value></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="DataAbertura"><Value>=Format(Fields!DataAbertura.Value, "dd/MM/yyyy")</Value></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="Status"><Value>=Fields!Status.Value</Value></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="ValorTotal"><Value>=FormatCurrency(Fields!ValorTotal.Value)</Value></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
          </TablixRows>
        </TablixBody>
        <TablixColumnHierarchy>
          <TablixMembers>
            <TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember />
          </TablixMembers>
        </TablixColumnHierarchy>
        <TablixRowHierarchy>
          <TablixMembers>
            <TablixMember />
            <TablixMember>
              <Group Name="Detalhe" />
            </TablixMember>
          </TablixMembers>
        </TablixRowHierarchy>
        <DataSetName>OrdensServicoDataSet</DataSetName>
        <Top>1.3cm</Top>
        <Left>0.5cm</Left>
        <Height>1.3cm</Height>
        <Width>16cm</Width>
      </Tablix>
      <Textbox Name="Titulo">
        <Value>Relatorio de Ordens de Servico</Value>
        <Top>0.3cm</Top>
        <Left>0.5cm</Left>
        <Height>0.6cm</Height>
        <Width>16cm</Width>
        <Style><FontSize>16pt</FontSize><FontWeight>Bold</FontWeight></Style>
      </Textbox>
      <Textbox Name="Resumo">
        <Value>="Total geral: " &amp; FormatCurrency(Sum(Fields!ValorTotal.Value, "OrdensServicoDataSet")) &amp; " | Total impostos: " &amp; FormatCurrency(Sum(Fields!TotalImpostos.Value, "OrdensServicoDataSet")) &amp; " | Quantidade OS: " &amp; CountDistinct(Fields!OrdemServicoId.Value, "OrdensServicoDataSet")</Value>
        <Top>2.8cm</Top>
        <Left>0.5cm</Left>
        <Height>0.6cm</Height>
        <Width>16cm</Width>
        <Style><FontWeight>Bold</FontWeight></Style>
      </Textbox>
    </ReportItems>
    <Height>4cm</Height>
  </Body>
  <Width>17cm</Width>
  <Page>
    <PageHeight>29.7cm</PageHeight>
    <PageWidth>21cm</PageWidth>
    <LeftMargin>1cm</LeftMargin>
    <RightMargin>1cm</RightMargin>
    <TopMargin>1cm</TopMargin>
    <BottomMargin>1cm</BottomMargin>
  </Page>
  <DataSources>
    <DataSource Name="OrdensServicoDataSource">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString>/* Local Connection */</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>9b3f839e-e40d-4e3a-b231-b646419f6b20</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="OrdensServicoDataSet">
      <Fields>
        <Field Name="ClienteId"><DataField>ClienteId</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="ClienteNome"><DataField>ClienteNome</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="OrdemServicoId"><DataField>OrdemServicoId</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="DataAbertura"><DataField>DataAbertura</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="Status"><DataField>Status</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ValorTotal"><DataField>ValorTotal</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="TotalImpostos"><DataField>TotalImpostos</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="QuantidadeOrdens"><DataField>QuantidadeOrdens</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
      </Fields>
      <Query>
        <DataSourceName>OrdensServicoDataSource</DataSourceName>
        <CommandText />
      </Query>
    </DataSet>
  </DataSets>
</Report>
